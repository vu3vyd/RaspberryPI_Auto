# =============================================================
#  .msmtprc — msmtp configuration for Gmail
#  Place this file at:  /home/pi/.msmtprc
#  Permissions MUST be: chmod 600 ~/.msmtprc
#
#  Gmail requirement:
#    Use an App Password — NOT your regular Gmail password.
#    Generate at: Google Account → Security →
#                 2-Step Verification → App Passwords
#    App: Mail   Device: Raspberry Pi
# =============================================================

defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        ~/.msmtp.log

account        gmail
host           smtp.gmail.com
port           587
from           your_gmail@gmail.com        # ← your Gmail address
user           your_gmail@gmail.com        # ← same Gmail address
password       YOUR_16_CHAR_APP_PASSWORD   # ← Gmail App Password (no spaces)

account default : gmail
